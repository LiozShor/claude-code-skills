# tech-researcher MCP credentials — template. Copy to .env and fill in real values.
# The authoritative store for MCP auth is ~/.claude.json (set via `claude mcp add`).

# Firecrawl — key embedded in the remote MCP URL. Get one at https://firecrawl.dev/app/api-keys
#   claude mcp add --transport http firecrawl "https://mcp.firecrawl.dev/$FIRECRAWL_API_KEY/v2/mcp"
FIRECRAWL_API_KEY=fc-your-firecrawl-key-here

# Exa — OAuth, NO API key needed. Just register and authenticate in the browser:
#   claude mcp add --transport http exa "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa"

# Tavily — managed claude.ai connector ("claude.ai Tavily"); no key stored locally.
