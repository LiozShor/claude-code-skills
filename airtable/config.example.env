# Airtable skill config — copy to `config.env` and fill in real values.
# `config.env` is gitignored; this template is safe to share / commit.
# To redeploy this skill against a different Airtable base, edit config.env only —
# no need to touch SKILL.md. (The API key stays in your project .env, not here.)

# Base ID (app…) — the Airtable base this skill operates on.
BASE_ID=appXXXXXXXXXXXXXX

# One var per table you query often (tbl…). Name them however you like; the
# convention is <TABLE>_TID. Reference these vars in commands — never raw tbl… IDs.
# Examples (replace with your own tables):
CONTACTS_TID=tblXXXXXXXXXXXXXX
PROJECTS_TID=tblXXXXXXXXXXXXXX
TASKS_TID=tblXXXXXXXXXXXXXX
