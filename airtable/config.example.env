# Airtable skill config — copy to `config.env` and fill in real values.
# `config.env` is gitignored; this template is safe to share / commit.
# To redeploy this skill against a different Airtable base, edit config.env only —
# no need to touch SKILL.md. (The API key stays in the project .env, not here.)

# Base ID (app…) — the Airtable base this skill operates on.
BASE_ID=appXXXXXXXXXXXXXX

# Core CRM tables (tbl…)
CLIENTS_TID=tblXXXXXXXXXXXXXX
REPORTS_TID=tblXXXXXXXXXXXXXX
DOCUMENTS_TID=tblXXXXXXXXXXXXXX
PENDING_TID=tblXXXXXXXXXXXXXX          # pending_classifications
TEMPLATES_TID=tblXXXXXXXXXXXXXX        # documents_templates
EMAIL_EVENTS_TID=tblXXXXXXXXXXXXXX

# Reference / config tables
QUESTION_MAPPINGS_TID=tblXXXXXXXXXXXXXX
CATEGORIES_TID=tblXXXXXXXXXXXXXX
SYSTEM_CONFIG_TID=tblXXXXXXXXXXXXXX
COMPANY_LINKS_TID=tblXXXXXXXXXXXXXX

# Data / log tables
QUESTIONNAIRE_TID=tblXXXXXXXXXXXXXX    # questionnaire answers
SYSTEM_LOGS_TID=tblXXXXXXXXXXXXXX
SECURITY_LOGS_TID=tblXXXXXXXXXXXXXX
